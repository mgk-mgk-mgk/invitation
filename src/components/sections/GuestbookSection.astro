---
import Section from '@/components/ui/Section.astro';
import defaultConfig from '@/lib/config';
import Guestbook from '@/components/islands/Guestbook.tsx';

const { config = defaultConfig } = Astro.props as { config?: typeof defaultConfig };
const { guestbook } = config;
---

<Section id="guestbook" label="Guestbook" title="축하 메시지">
  <Guestbook client:visible allowPassword={guestbook.allowPassword} />
</Section>
