---
import Section from '@/components/ui/Section.astro';
import defaultConfig from '@/lib/config';
import { monthGrid, dateKoFull, dayOfWeekEn } from '@/lib/datetime';

const { config = defaultConfig } = Astro.props as { config?: typeof defaultConfig };
const { cover, calendar } = config;
const g = monthGrid(cover.datetimeISO);
const weekdays = ['일', '월', '화', '수', '목', '금', '토'];

// 달력 셀 배열(앞쪽 빈칸 + 날짜)
const cells: (number | null)[] = [
  ...Array.from({ length: g.firstDow }, () => null),
  ...Array.from({ length: g.daysInMonth }, (_, i) => i + 1),
];

const weddingDayDow = dayOfWeekEn(cover.datetimeISO);
const fullDate = dateKoFull(cover.datetimeISO);
const [dateLine, timeLine] = fullDate.split(/ (?=오전|오후)/);
---

<Section id="calendar" label="The Date" title="예식 안내">
  <p class="cal__full center">
    <span>{dateLine}</span>
    <span>{timeLine}</span>
  </p>

  <table class="cal" role="presentation">
    <thead>
      <tr>{weekdays.map((w, i) => <th class:list={[i === 0 && 'cal--sun', i === 6 && 'cal--sat']}>{w}</th>)}</tr>
    </thead>
    <tbody>
      {Array.from({ length: Math.ceil(cells.length / 7) }, (_, row) => (
        <tr>
          {cells.slice(row * 7, row * 7 + 7).map((d, col) => (
            <td class:list={[d === g.weddingDay && 'cal__wed', col === 0 && d && 'cal--sun', col === 6 && d && 'cal--sat']}>
              {d ? <span>{d}</span> : ''}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>

  {calendar.showCountdown && (
    <p class="cal__countdown" data-target={cover.datetimeISO}>
      <span id="dday-label">D-DAY</span>
      <span class="muted"> · {weddingDayDow}</span>
    </p>
  )}
</Section>

<style>
  .cal__full {
    font-family: var(--font-serif-ko);
    font-size: 1.05rem;
    line-height: 1.8;
    margin: 0 0 1.5rem;
  }
  .cal__full span {
    display: block;
  }
  .cal {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed; /* 7열 균등 — 예식일 강조 동그라미가 토요일 열만 넓히던 문제 방지 */
    text-align: center;
    max-width: 19rem;
    margin: 0 auto 1.5rem;
  }
  .cal th {
    font-size: 0.75rem;
    color: var(--c-ink-soft);
    font-weight: 500;
    padding-bottom: 0.6rem;
  }
  .cal td {
    height: 2.4rem;
    font-size: 0.9rem;
    color: var(--c-ink);
  }
  .cal th.cal--sun,
  .cal td.cal--sun { color: #d33a32; }
  .cal th.cal--sat,
  .cal td.cal--sat { color: #1f6fd1; }
  .cal__wed span {
    display: inline-grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: var(--c-accent);
    color: #fff;
    font-weight: 700;
  }
  .cal__countdown {
    text-align: center;
    font-family: var(--font-serif-en);
    font-size: 1.3rem;
    letter-spacing: 0.08em;
    color: var(--c-accent);
    margin: 0 0 1.5rem;
  }
</style>

<script>
  import { dDayLabel } from '@/lib/datetime';
  const el = document.querySelector<HTMLElement>('.cal__countdown');
  const label = document.getElementById('dday-label');
  if (el && label) {
    const target = el.dataset.target;
    if (target) label.textContent = dDayLabel(target);
  }
</script>
