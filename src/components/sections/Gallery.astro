---
import Section from '@/components/ui/Section.astro';
import defaultConfig from '@/lib/config';
import Lightbox from '@/components/islands/Lightbox.tsx';

const { config = defaultConfig } = Astro.props as { config?: typeof defaultConfig };
const { gallery } = config;
---

<Section id="gallery" label="Gallery" title="우리의 순간">
  <div class:list={['grid', gallery.layout === 'carousel' && 'grid--scroll']}>
    {gallery.images.map((img, i) => (
      <button type="button" class="grid__item" data-gallery-item data-index={i} aria-label={`사진 ${i + 1} 크게 보기`}>
        {/* 그리드는 가벼운 정사각 썸네일(thumb/). 확대(라이트박스)는 원본(img.src)을 사용. */}
        <img src={img.src.replace('/gallery/', '/gallery/thumb/')} alt={img.alt} loading="lazy" decoding="async" width="400" height="400" />
      </button>
    ))}
  </div>

  <!-- 풀스크린 뷰어(섬) — 닫힌 상태엔 아무것도 안 그리므로 client:visible 이면 영영 hydrate 안 됨.
       클릭 위임 리스너가 붙어야 썸네일 클릭 → 확대가 동작하므로 client:idle 로 확실히 hydrate. -->
  <Lightbox client:idle images={gallery.images} />
</Section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }
  .grid--scroll {
    grid-auto-flow: column;
    grid-template-columns: none;
    grid-auto-columns: 70%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }
  .grid--scroll .grid__item { scroll-snap-align: center; }
  .grid__item {
    padding: 0;
    border: none;
    background: var(--c-line);
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    cursor: pointer;
  }
  .grid__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
