---
import Section from '@/components/ui/Section.astro';
import config from '@/lib/config';

const { notices } = config;
const items = [...notices.items];
if (notices.declineWreath && !items.some((i) => i.title.includes('화환'))) {
  items.unshift({ title: '화환', body: '화환은 정중히 사양합니다. 축하해 주시는 마음만 감사히 받겠습니다.' });
}
---

<Section id="notices" label="Notice" title="안내 사항">
  <div class="notices">
    {items.map((n) => (
      <div class="notices__card">
        <p class="notices__title">{n.title}</p>
        <p class="notices__body muted">{n.body}</p>
      </div>
    ))}
  </div>
</Section>

<style>
  .notices { display: grid; gap: 0.7rem; }
  .notices__card {
    border: 1px solid var(--c-line);
    border-radius: var(--radius);
    background: var(--c-surface);
    padding: 1rem 1.1rem;
    text-align: center;
  }
  .notices__title { margin: 0 0 0.3rem; font-family: var(--font-serif-ko); color: var(--c-accent); }
  .notices__body { margin: 0; font-size: 0.88rem; white-space: pre-line; }
</style>
