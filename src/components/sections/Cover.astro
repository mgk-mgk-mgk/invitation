---
import defaultConfig from '@/lib/config';
import { dateHero, dateKoFull } from '@/lib/datetime';

const { config = defaultConfig } = Astro.props as { config?: typeof defaultConfig };
const { cover } = config;
const hero = dateHero(cover.datetimeISO, cover.dateHeroStyle);
const full = dateKoFull(cover.datetimeISO);
---

<header class="cover">
  <div class="cover__media">
    <img
      src={cover.heroImage}
      alt={`${cover.groomName} ${cover.brideName} 결혼합니다`}
      width="860"
      height="1146"
      fetchpriority="high"
      decoding="async"
    />
    <div class="cover__scrim" aria-hidden="true"></div>
  </div>

  <div class="cover__content">
    <p class="cover__names">{cover.groomName} <span>·</span> {cover.brideName}</p>
    <p class="cover__date">{hero}</p>
    <p class="cover__meta">{full}</p>
    <p class="cover__meta">{cover.venueShort}</p>
  </div>

  {cover.scrollCue && (
    <div class="cover__cue" aria-hidden="true">
      <span>{cover.scrollCue}</span>
      <span class="cover__cue-arrow">⌄</span>
    </div>
  )}
</header>

<style>
  .cover {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: #fff;
    overflow: hidden;
  }
  .cover__media,
  .cover__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cover__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.15) 0%, rgba(0, 0, 0, 0) 35%, rgba(0, 0, 0, 0.45) 100%);
  }
  .cover__content {
    position: relative;
    text-align: center;
    padding: 0 1.5rem 4.5rem;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.35);
  }
  .cover__names {
    font-family: var(--font-serif-ko);
    font-size: 1.5rem;
    letter-spacing: 0.06em;
    margin: 0 0 1rem;
  }
  .cover__names span { color: var(--c-accent-soft); margin: 0 0.3rem; }
  .cover__date {
    font-family: var(--font-serif-en);
    font-size: var(--fs-hero);
    line-height: 1.1;
    letter-spacing: 0.04em;
    margin: 0 0 1.2rem;
  }
  .cover__meta {
    font-size: 0.9rem;
    margin: 0.15rem 0;
    opacity: 0.95;
  }
  .cover__cue {
    position: absolute;
    bottom: 1.4rem;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    opacity: 0.85;
  }
  .cover__cue-arrow {
    display: block;
    font-size: 1.1rem;
    animation: bob 1.6s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .cover__cue-arrow { animation: none; }
  }
</style>
