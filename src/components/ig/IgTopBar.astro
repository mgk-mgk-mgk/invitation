---
import { more, share as shareIcon, link as linkIcon, verified } from './icons';
import BgmToggle from '@/components/ui/BgmToggle.astro';

interface SharePayload {
  title: string;
  description: string;
  imageUrl: string; // 절대 https
  linkUrl: string;  // 절대 https
}

interface Props {
  handle: string;
  share: SharePayload;
  bgmSrc?: string;  // 있으면 상단바 아이디 왼쪽에 음악 토글 배치
}
const { handle, share: s, bgmSrc } = Astro.props;
---

{/* 음악 토글은 아이디 왼쪽, ⋮ 메뉴는 우측(공유하기·링크복사). 뒤로가기 화살표는 제거. */}
<header class="ig-top">
  {bgmSrc && <BgmToggle src={bgmSrc} />}
  <span class="ig-top__user">{handle}<span class="ig-vrf" set:html={verified} /></span>
  <details class="ig-menu" data-autoclose>
    <summary class="ig-top__more" aria-label="메뉴"><Fragment set:html={more} /></summary>
    <div class="ig-menu__sheet" role="menu">
      <button
        type="button"
        role="menuitem"
        data-share-kakao
        data-title={s.title}
        data-desc={s.description}
        data-image={s.imageUrl}
        data-link={s.linkUrl}
      ><span class="ig-menu__ic" set:html={shareIcon} />공유하기</button>
      <button
        type="button"
        role="menuitem"
        data-copy-link
        data-link={s.linkUrl}
      ><span class="ig-menu__ic" set:html={linkIcon} />링크복사</button>
    </div>
  </details>
</header>
