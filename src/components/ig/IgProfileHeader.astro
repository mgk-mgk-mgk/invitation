---
import { verified } from './icons';
import { dateHero } from '@/lib/datetime';
import type { WeddingConfig } from '@/types/wedding';

interface Props {
  config: WeddingConfig;
  handle: string;
  postCount: number;
}
const { config, postCount } = Astro.props;
const { cover, gallery, greeting, accounts } = config;
const avatar = cover.profileImage ?? cover.heroImage;

const tagline = greeting.message.split('\n')[0];
const dateLine = dateHero(cover.datetimeISO, cover.dateHeroStyle ?? 'YYYY.MM.DD DAY');

// 메시지 보내기 — 실제 문자(SMS) 앱을 엽니다. 대상이 둘이면 선택 팝오버, 하나면 바로 링크.
// 신부는 일단 제외(번호 준비되면 아래 brideSms 의 주석을 해제).
const smsHref = (p?: string) => (p ? `sms:${p.replace(/[^0-9+]/g, '')}` : null);
const groomSms = smsHref(greeting.groom.person.phone);
const brideSms: string | null = null; // smsHref(greeting.bride.person.phone);
const msgTargets = [
  groomSms && { href: groomSms, label: '신랑에게 문자' },
  brideSms && { href: brideSms, label: '신부에게 문자' },
].filter(Boolean) as { href: string; label: string }[];
---

<section class="ig-profile">
  <span class="ig-ring"><img src={avatar} alt="프로필 사진" width="84" height="84" /></span>
  <div class="ig-stats">
    <div><b>{postCount}</b><span>게시물</span></div>
    <div><b>{gallery.images.length}</b><span>사진</span></div>
    <div><b data-dday data-target={cover.datetimeISO}>D-…</b><span>예식까지</span></div>
  </div>
</section>

<div class="ig-name">
  {cover.groomName} <span class="heart">♥</span> {cover.brideName}
  <span class="ig-vrf" set:html={verified} />
</div>

<div class="ig-bio">
  <p>📅 {dateLine}</p>
  <p>📍 {cover.venueShort}</p>
  <p class="ig-bio__tag">💌 {tagline}</p>
</div>

<div class="ig-actions">
  <button class="ig-btn ig-btn--primary is-following" type="button" data-follow>팔로잉</button>
  {msgTargets.length > 1 ? (
    <details class="ig-msg" data-autoclose>
      <summary class="ig-btn ig-btn--secondary">메시지 보내기</summary>
      <div class="ig-msg__menu" role="menu">
        {msgTargets.map((m) => <a role="menuitem" href={m.href}>{m.label}</a>)}
      </div>
    </details>
  ) : msgTargets.length === 1 ? (
    <a class="ig-btn ig-btn--secondary" href={msgTargets[0].href} aria-label={msgTargets[0].label}>메시지 보내기</a>
  ) : (
    accounts.enabled && <a class="ig-btn ig-btn--secondary" href="#post-accounts" data-target="#post-accounts">메시지</a>
  )}
</div>
